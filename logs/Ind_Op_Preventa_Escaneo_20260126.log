            	    	WHEN MONTH (Fecha_operacion) = 1 THEN 'Ene'
            	    	WHEN MONTH (Fecha_operacion) = 2 THEN 'Feb'
            	    	WHEN MONTH (Fecha_operacion) = 3 THEN 'Mar'
            	    	WHEN MONTH (Fecha_operacion) = 4 THEN 'Abr'
            	    	WHEN MONTH (Fecha_operacion) = 5 THEN 'May'
